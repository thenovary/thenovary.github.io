---
/**
 * About page — /ko/about/ and /en/about/
 */
import Layout from '../../components/Layout.astro';
import { getLang, t } from '../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'ko' } },
    { params: { lang: 'en' } },
  ];
}

const lang = getLang(Astro.params.lang);

const isKo = lang === 'ko';
---

<Layout
  lang={lang}
  title={isKo ? '소개' : 'About'}
  description={isKo ? 'thenovary — 이름의 의미와 브랜드 철학' : 'thenovary — The meaning behind the name and our brand philosophy'}
>
  <section class="section about-page">
    <div class="container">

      <!-- Brand name etymology -->
      <div class="about-hero">
        <p class="eyebrow">{isKo ? '이름의 의미' : 'The Name'}</p>
        <h1 class="brand-name">thenovary</h1>
        <p class="brand-tagline">
          {isKo
            ? '새로움을 만들어갑니다'
            : 'Creating the new'}
        </p>
      </div>

      <!-- Etymology graphic -->
      <div class="origin-graphic glass-card">
        <div class="origin-header">
          <div>
            <p class="origin-kicker">{isKo ? '브랜드 어원' : 'Brand Etymology'}</p>
            <h2 class="origin-title">
              {isKo
                ? '두 어원이 만나 브랜드를 정의합니다'
                : 'Two roots come together to define the brand.'}
            </h2>
            <p class="origin-summary">
              {isKo
                ? 'nova의 폭발적인 시작과 -ary의 성격이 결합해, thenovary라는 이름 안에 새로운 것을 계속 만들어내는 정체성을 담아냅니다.'
                : 'The spark of nova and the defining character of -ary converge into thenovary, a name built to keep creating what is new.'}
            </p>
          </div>
        </div>

        <div class="origin-stage">
          <article class="origin-token origin-token-nova">
            <span class="origin-token-meta">Root 01</span>
            <strong class="origin-token-word">nova</strong>
            <p class="origin-token-desc">
              {isKo ? (
                <>
                  <span class="origin-token-desc-desktop">새로운 것, 혁신, 폭발적인 시작</span>
                  <span class="origin-token-desc-mobile">새로운 것, 혁신,<br />폭발적인 시작</span>
                </>
              ) : (
                'Something new, innovation, an explosive beginning'
              )}
            </p>
          </article>

          <div class="origin-operator" aria-hidden="true">+</div>

          <article class="origin-token origin-token-ary">
            <span class="origin-token-meta">Root 02</span>
            <strong class="origin-token-word">-ary</strong>
            <p class="origin-token-desc">
              {isKo ? (
                <>
                  <span class="origin-token-desc-desktop">그러한 성격을 가진, ~에 속한</span>
                  <span class="origin-token-desc-mobile">그러한 성격을 가진,<br />~에 속한</span>
                </>
              ) : (
                'Of or relating to, having the quality of'
              )}
            </p>
          </article>
        </div>

        <div class="fusion-core" aria-hidden="true">
          <span class="fusion-line fusion-line-left"></span>
          <span class="fusion-line fusion-line-right"></span>
          <span class="fusion-ring fusion-ring-large"></span>
          <span class="fusion-ring fusion-ring-small"></span>
          <span class="fusion-spark"></span>
        </div>

        <div class="result-stage">
          <div class="result-equation" aria-hidden="true">=</div>
          <div class="result-card">
            <p class="result-meta">Created Identity</p>
            <h3 class="result-word">thenovary</h3>
            <p class="result-desc">
              {isKo
                ? '새로움을 만들어갑니다'
                : 'Creating the new'}
            </p>
            <p class="result-note">
              {isKo
                ? '새로움을 발견하는 것을 넘어, 그것을 실제 경험으로 탄생시키는 이름입니다.'
                : 'A name that goes beyond discovering newness and brings it to life as a real experience.'}
            </p>
          </div>
        </div>
      </div>

      <!-- Maker section -->
      <div class="maker-section">
        <div class="maker-card glass-card">
          <p class="maker-label">{isKo ? '만든 이' : 'Maker'}</p>
          <div class="maker-avatar">
            <div class="maker-avatar-shell">
              <span class="maker-avatar-orbit" aria-hidden="true"></span>
              <img
                src="/profile.png"
                alt={isKo ? 'thenovary 프로필 이미지' : 'thenovary profile image'}
                class="maker-avatar-image"
                loading="lazy"
              />
            </div>
          </div>
          <div class="maker-info">
            <h2 class="maker-name">Yujin</h2>
            <div class="maker-tags" aria-label={isKo ? '담당 역할' : 'Roles'}>
              {isKo ? (
                <>
                  <span class="maker-tag">기획</span>
                  <span class="maker-tag">디자인</span>
                  <span class="maker-tag">개발</span>
                </>
              ) : (
                <>
                  <span class="maker-tag">Planner</span>
                  <span class="maker-tag">Designer</span>
                  <span class="maker-tag">Developer</span>
                </>
              )}
            </div>
            <p class="maker-bio">
              {isKo
                ? '일상의 작은 불편함을 해결하는 앱을 만듭니다.\n제품 하나하나를 처음부터 끝까지 직접 기획·디자인·개발하는 1인 메이커입니다.'
                : 'Building apps that solve small frustrations in everyday life.\nI\'m a solo maker who plans, designs, and develops each product from start to finish.'}
            </p>
          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style>
  .about-page {
    padding-top: var(--space-3xl);
    padding-bottom: var(--space-3xl);
    min-height: calc(80vh - var(--gnb-height));
  }

  .about-hero {
    text-align: center;
    margin-bottom: var(--space-2xl);
    max-width: 760px;
    margin-inline: auto;
  }

  .eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .brand-name {
    font-size: clamp(42px, 7vw, 76px);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--color-text-primary);
    line-height: 1;
    margin-bottom: var(--space-md);
  }

  .brand-tagline {
    font-size: clamp(15px, 1.7vw, 18px);
    color: var(--color-text-secondary);
    font-style: italic;
    margin-bottom: var(--space-sm);
  }

  .origin-graphic {
    position: relative;
    max-width: 860px;
    margin: 0 auto var(--space-2xl);
    padding: clamp(20px, 4vw, 32px);
    overflow: hidden;
  }

  .origin-graphic::before {
    content: '';
    position: absolute;
    left: -8%;
    bottom: -18%;
    width: 280px;
    height: 280px;
    background: radial-gradient(circle, rgba(91, 92, 255, 0.22) 0%, rgba(91, 92, 255, 0) 72%);
    pointer-events: none;
  }

  .origin-graphic::after {
    content: '';
    position: absolute;
    top: -18%;
    right: -10%;
    width: 320px;
    height: 320px;
    background: radial-gradient(circle, rgba(0, 210, 255, 0.18) 0%, rgba(0, 210, 255, 0) 72%);
    pointer-events: none;
  }

  .origin-header,
  .origin-stage,
  .fusion-core,
  .result-stage {
    position: relative;
    z-index: 1;
  }

  .origin-header {
    max-width: 820px;
    margin-bottom: clamp(18px, 3vw, 28px);
  }

  .origin-kicker {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .origin-title {
    font-size: clamp(24px, 3.4vw, 34px);
    line-height: 1.12;
    letter-spacing: -0.035em;
    color: var(--color-text-primary);
  }

  .origin-summary {
    margin-top: 12px;
    font-size: 14px;
    color: var(--color-text-secondary);
    line-height: 1.65;
    max-width: 100%;
  }

  .origin-stage {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    gap: clamp(10px, 1.4vw, 14px);
    align-items: center;
  }

  .origin-token {
    min-height: 172px;
    padding: clamp(14px, 2vw, 18px);
    border-radius: 22px;
    border: 1px solid rgba(255, 255, 255, 0.9);
    box-shadow: 0 12px 30px rgba(19, 23, 44, 0.08);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--space-sm);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .origin-token-nova {
    background: linear-gradient(135deg, rgba(91, 92, 255, 0.14) 0%, rgba(255, 255, 255, 0.92) 52%, rgba(255, 255, 255, 0.78) 100%);
  }

  .origin-token-ary {
    background: linear-gradient(135deg, rgba(0, 210, 255, 0.12) 0%, rgba(255, 255, 255, 0.92) 52%, rgba(255, 255, 255, 0.8) 100%);
  }

  .origin-token-meta {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    padding: 5px 9px;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.9);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .origin-token-word {
    font-size: clamp(30px, 5vw, 48px);
    line-height: 0.95;
    letter-spacing: -0.05em;
    color: var(--color-text-primary);
  }

  .origin-token-desc {
    font-size: 14px;
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: none;
  }

  .origin-token-desc-desktop {
    display: block;
  }

  .origin-token-desc-mobile {
    display: none;
  }

  .origin-operator {
    width: clamp(40px, 4.6vw, 50px);
    height: clamp(40px, 4.6vw, 50px);
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: rgba(255, 255, 255, 0.86);
    border: 1px solid rgba(255, 255, 255, 0.95);
    box-shadow: 0 7px 18px rgba(19, 23, 44, 0.08);
    font-size: clamp(18px, 2.5vw, 24px);
    font-weight: 600;
    color: var(--color-accent);
  }

  .fusion-core {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 88px;
    margin: clamp(8px, 2vw, 14px) 0;
  }

  .fusion-line {
    position: absolute;
    top: 50%;
    width: clamp(88px, 20vw, 180px);
    height: 1px;
    background: linear-gradient(90deg, rgba(91, 92, 255, 0), rgba(91, 92, 255, 0.45), rgba(91, 92, 255, 0));
  }

  .fusion-line-left {
    left: calc(50% - clamp(98px, 22vw, 192px));
  }

  .fusion-line-right {
    right: calc(50% - clamp(98px, 22vw, 192px));
  }

  .fusion-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(91, 92, 255, 0.24);
    animation: fusion-pulse 5s ease-in-out infinite;
  }

  .fusion-ring-large {
    width: 78px;
    height: 78px;
  }

  .fusion-ring-small {
    width: 48px;
    height: 48px;
    animation-delay: 0.8s;
  }

  .fusion-spark {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, #ffffff 0%, #8cecff 38%, #5b5cff 100%);
    box-shadow:
      0 0 0 8px rgba(91, 92, 255, 0.08),
      0 0 22px rgba(91, 92, 255, 0.35);
    animation: spark-glow 4s ease-in-out infinite;
  }

  .result-stage {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: clamp(10px, 1.4vw, 14px);
    align-items: stretch;
  }

  .result-equation {
    width: clamp(40px, 4.6vw, 50px);
    min-height: 100%;
    border-radius: 999px;
    display: grid;
    place-items: center;
    background: rgba(255, 255, 255, 0.84);
    border: 1px solid rgba(255, 255, 255, 0.95);
    box-shadow: 0 7px 18px rgba(19, 23, 44, 0.08);
    font-size: clamp(18px, 2.5vw, 24px);
    font-weight: 600;
    color: var(--color-accent);
  }

  .result-card {
    padding: clamp(16px, 2.4vw, 20px);
    border-radius: 22px;
    background:
      radial-gradient(circle at 18% 22%, rgba(91, 92, 255, 0.26) 0%, rgba(91, 92, 255, 0) 34%),
      radial-gradient(circle at 88% 18%, rgba(0, 210, 255, 0.22) 0%, rgba(0, 210, 255, 0) 36%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.96) 0%, rgba(238, 241, 255, 0.96) 46%, rgba(228, 246, 255, 0.94) 100%);
    border: 1px solid rgba(255, 255, 255, 0.96);
    color: var(--color-text-primary);
    box-shadow: 0 14px 34px rgba(91, 92, 255, 0.14);
  }

  .result-meta {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(91, 92, 255, 0.82);
    margin-bottom: var(--space-sm);
  }

  .result-word {
    font-size: clamp(32px, 5vw, 54px);
    line-height: 0.95;
    letter-spacing: -0.055em;
    margin-bottom: 10px;
    color: #1a1c30;
  }

  .result-desc {
    font-size: clamp(16px, 2vw, 20px);
    line-height: 1.35;
    letter-spacing: -0.03em;
    margin-bottom: 12px;
    color: rgba(26, 28, 48, 0.92);
  }

  .result-note {
    max-width: 72ch;
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-text-secondary);
  }

  /* Maker section */
  .maker-section {
    max-width: 860px;
    margin: var(--space-xl) auto 0;
  }

  .maker-card {
    position: relative;
    padding: clamp(20px, 3vw, 28px);
    display: grid;
    grid-template-columns: 156px minmax(0, 1fr);
    column-gap: clamp(18px, 3vw, 28px);
    row-gap: 12px;
    align-items: center;
    overflow: hidden;
    background:
      radial-gradient(circle at 18% 24%, rgba(91, 92, 255, 0.1) 0%, rgba(91, 92, 255, 0) 32%),
      radial-gradient(circle at 88% 18%, rgba(0, 210, 255, 0.1) 0%, rgba(0, 210, 255, 0) 30%),
      rgba(255, 255, 255, 0.72);
  }

  .maker-card::before {
    content: '';
    position: absolute;
    inset: auto -8% -28% auto;
    width: 240px;
    height: 240px;
    background: radial-gradient(circle, rgba(91, 92, 255, 0.1) 0%, rgba(91, 92, 255, 0) 70%);
    pointer-events: none;
  }

  .maker-avatar {
    flex-shrink: 0;
    position: relative;
    z-index: 1;
    grid-column: 1;
    grid-row: 2;
  }

  .maker-avatar::before {
    content: '';
    position: absolute;
    left: -10px;
    bottom: 6px;
    width: 54px;
    height: 54px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.92) 0%, rgba(111, 216, 255, 0.32) 42%, rgba(111, 216, 255, 0) 74%);
    filter: blur(4px);
    opacity: 0.9;
    pointer-events: none;
  }

  .maker-avatar::after {
    content: '';
    position: absolute;
    top: 10px;
    right: 2px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: radial-gradient(circle, #ffffff 0%, rgba(255, 255, 255, 0.9) 28%, rgba(91, 92, 255, 0.55) 62%, rgba(91, 92, 255, 0) 100%);
    box-shadow:
      0 0 0 6px rgba(91, 92, 255, 0.06),
      0 0 18px rgba(91, 92, 255, 0.22);
    pointer-events: none;
  }

  .maker-avatar-shell {
    width: clamp(128px, 16vw, 156px);
    aspect-ratio: 1;
    position: relative;
    display: grid;
    place-items: center;
  }

  .maker-avatar-orbit {
    position: absolute;
    inset: -8px;
    border-radius: 42px;
    border: 1px solid rgba(255, 255, 255, 0.75);
    background:
      linear-gradient(135deg, rgba(91, 92, 255, 0.08), rgba(255, 255, 255, 0) 40%, rgba(0, 210, 255, 0.1));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.46),
      0 16px 36px rgba(91, 92, 255, 0.1);
    transform: rotate(-6deg);
    pointer-events: none;
  }

  .maker-avatar-shell::before {
    content: '';
    position: absolute;
    inset: 10px;
    border-radius: 34px;
    background:
      radial-gradient(circle at 26% 24%, rgba(91, 92, 255, 0.26) 0%, rgba(91, 92, 255, 0.02) 44%, rgba(91, 92, 255, 0) 68%),
      radial-gradient(circle at 76% 24%, rgba(0, 210, 255, 0.22) 0%, rgba(0, 210, 255, 0.02) 42%, rgba(0, 210, 255, 0) 66%),
      radial-gradient(circle at 50% 72%, rgba(255, 255, 255, 0.52) 0%, rgba(255, 255, 255, 0.08) 42%, rgba(255, 255, 255, 0) 70%);
    filter: blur(12px);
    box-shadow: 0 18px 32px rgba(91, 92, 255, 0.12);
    pointer-events: none;
  }

  .maker-avatar-shell::after {
    content: '';
    position: absolute;
    inset: 4px;
    border-radius: 38px;
    background:
      linear-gradient(135deg, rgba(91, 92, 255, 0.14), rgba(255, 255, 255, 0.04) 44%, rgba(0, 210, 255, 0.14));
    border: 1px solid rgba(255, 255, 255, 0.9);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.5),
      0 12px 24px rgba(91, 92, 255, 0.08);
    opacity: 0.95;
    pointer-events: none;
  }

  .maker-avatar-image {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: transparent;
    transform: scale(1.02);
    filter: drop-shadow(0 14px 24px rgba(45, 55, 115, 0.2));
  }

  .maker-info {
    flex: 1;
    min-width: 0;
    position: relative;
    z-index: 1;
    grid-column: 2;
    grid-row: 2;
  }

  .maker-label {
    grid-column: 1;
    grid-row: 1;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0;
  }

  .maker-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-bottom: 10px;
    margin-top: 0;
  }

  .maker-name {
    font-size: clamp(24px, 3vw, 30px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
    margin-bottom: 10px;
  }

  .maker-tag {
    display: inline-flex;
    align-items: center;
    padding: 4px 7px;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.74);
    border: 1px solid rgba(255, 255, 255, 0.92);
    box-shadow: 0 6px 16px rgba(91, 92, 255, 0.06);
    font-size: 10px;
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .maker-bio {
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-text-secondary);
    white-space: pre-line;
    max-width: 72ch;
  }

  @keyframes fusion-pulse {
    0%,
    100% {
      transform: scale(0.92);
      opacity: 0.5;
    }

    50% {
      transform: scale(1.06);
      opacity: 1;
    }
  }

  @keyframes spark-glow {
    0%,
    100% {
      transform: scale(0.95);
      box-shadow:
        0 0 0 10px rgba(91, 92, 255, 0.08),
        0 0 30px rgba(91, 92, 255, 0.35);
    }

    50% {
      transform: scale(1.12);
      box-shadow:
        0 0 0 16px rgba(91, 92, 255, 0.08),
        0 0 40px rgba(111, 216, 255, 0.4);
    }
  }

  @media (max-width: 860px) {
    .origin-summary {
      max-width: none;
    }

    .origin-stage {
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      gap: 10px;
    }

    .fusion-core {
      height: 82px;
    }

    .fusion-line {
      width: 18vw;
    }

    .result-stage {
      grid-template-columns: auto minmax(0, 1fr);
    }
  }

  @media (max-width: 640px) {
    .brand-caption,
    .origin-summary,
    .origin-token-desc,
    .result-note {
      font-size: 14px;
    }

    .origin-token {
      min-height: 148px;
      padding: 12px;
      border-radius: 18px;
    }

    .origin-stage {
      grid-template-columns: minmax(0, 1fr) 34px minmax(0, 1fr);
      gap: 8px;
    }

    .origin-token-meta {
      padding: 4px 7px;
      font-size: 9px;
    }

    .origin-token-word {
      font-size: clamp(22px, 6.6vw, 30px);
    }

    .origin-token-desc {
      font-size: 12px;
      line-height: 1.45;
    }

    .origin-token-desc-desktop {
      display: none;
    }

    .origin-token-desc-mobile {
      display: block;
    }

    .origin-operator {
      width: 34px;
      height: 34px;
      font-size: 16px;
    }

    .fusion-core {
      height: 66px;
      margin: 10px 0;
    }

    .fusion-line {
      width: 20vw;
    }

    .fusion-ring-large {
      width: 58px;
      height: 58px;
    }

    .fusion-ring-small {
      width: 36px;
      height: 36px;
    }

    .fusion-spark {
      width: 12px;
      height: 12px;
    }

    .result-stage {
      grid-template-columns: 34px minmax(0, 1fr);
      gap: 8px;
    }

