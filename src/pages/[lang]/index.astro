---
/**
 * Home page — /ko/ and /en/
 */
import RenewalLayout from '../../components/RenewalLayout.astro';
import RenewalAppCard from '../../components/RenewalAppCard.astro';
import { getLang, t } from '../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'ko' } },
    { params: { lang: 'en' } },
  ];
}

const lang = getLang(Astro.params.lang);
const isArchivePreview = Astro.url.searchParams.get('preview') === 'archive';

const appFiles = import.meta.glob('../../data/apps/*.json', { eager: true });
const apps = Object.values(appFiles)
  .map(m => (m as { default: unknown }).default ?? m)
  .sort((a: any, b: any) => b.order - a.order);
---

<RenewalLayout
  lang={lang}
  basePath=""
  title="thenovary"
  description={lang === 'ko'
    ? '혁신적인 앱을 만드는 스튜디오 thenovary'
    : 'thenovary — A studio that crafts innovative apps'}
>
  <!-- Hero section -->
  <section class:list={['hero', isArchivePreview && 'hero--archive-preview']} data-scroll-orbit>
    <div class="container hero-inner">
      <!-- Left: text content -->
      <div class="hero-text">
        <p class="hero-eyebrow">{t(lang, 'home.eyebrow')}</p>
        <h1 class="hero-headline">
          <span>{t(lang, 'home.headline1')}</span><br />
          <span>{t(lang, 'home.headline2')}</span>
        </h1>
        {lang === 'ko' && <p class="hero-headline-note">{t(lang, 'home.headlineNote')}</p>}
        <p class="hero-subtitle">{t(lang, 'home.subtitle')}</p>
        <div class="hero-cta-row">
          <a href="#apps" class="btn btn-primary">{t(lang, 'home.ctaPrimary')}</a>
          <a href={`/${lang}/contact/`} class="btn btn-secondary">{t(lang, 'home.ctaSecondary')}</a>
        </div>
      </div>

      <!-- Right: Floating glass card composition -->
      <div class="hero-visual">
        <div class="glass-comp">
          <!-- Background aurora glow blobs -->
          <div class="comp-glow glow-violet"></div>
          <div class="comp-glow glow-blue"></div>
          <div class="comp-glow glow-cyan"></div>

          <!-- Main glass card -->
          <div class="card-main-wrap">
            <div class="card-main">
              <div class="card-gradient"></div>
            </div>
          </div>

          <!-- Decorative dots -->
          <div class="cdot cdot-1"></div>
          <div class="cdot cdot-2"></div>
          <div class="cdot cdot-3"></div>
          <div class="cdot cdot-4"></div>
          <div class="cdot cdot-5"></div>
        </div>
      </div>
    </div>
  </section>

  {!isArchivePreview && (
    <section class="section-sm apps-section" id="apps">
      <div class="container">
        <h2 class="section-title">{t(lang, 'home.appsTitle')}</h2>
        <div class="apps-grid">
          {apps.map((app: any) => (
            <RenewalAppCard app={app} lang={lang} basePath="" />
          ))}
        </div>
      </div>
    </section>
  )}
</RenewalLayout>

{!isArchivePreview && (
  <script is:inline>
    (() => {
      if (typeof window === 'undefined') return;

      const previousCleanup = window.__thenovaryOrbitCleanup;
      if (typeof previousCleanup === 'function') previousCleanup();

      const heroes = Array.from(document.querySelectorAll('[data-scroll-orbit]:not(.hero--archive-preview)'));
      if (!heroes.length) return;

      const mediaQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
      let rafId = 0;

      const easeOutCubic = (value) => 1 - Math.pow(1 - value, 3);

      const resetHero = (hero) => {
        hero.style.setProperty('--scroll-progress', '0');
        hero.style.setProperty('--hero-text-shift', '0px');
        hero.style.setProperty('--hero-visual-shift', '-8px');
        hero.style.setProperty('--visual-tilt', '0deg');
        hero.style.setProperty('--field-turn', '0deg');
        hero.style.setProperty('--back-ring-drift', '0px');
        hero.style.setProperty('--front-ring-drift', '0px');
        hero.style.setProperty('--front-ring-turn', '0deg');
        hero.style.setProperty('--front-ring-scale', '1');
        hero.style.setProperty('--rear-ring-scale', '1');
        hero.style.setProperty('--surface-turn', '0deg');
        hero.style.setProperty('--aura-scale', '1');
        hero.style.setProperty('--aura-opacity', '0.92');
        hero.style.setProperty('--orb-saturate', '1');
        hero.style.setProperty('--orb-brightness', '1');
        hero.style.setProperty('--orb-outline-opacity', '0.42');
        hero.style.setProperty('--spark-drift', '0px');
      };

      const update = () => {
        rafId = 0;

        if (mediaQuery.matches) {
          heroes.forEach(resetHero);
          return;
        }

        const viewportHeight = window.innerHeight || 1;

        heroes.forEach((hero) => {
          const rect = hero.getBoundingClientRect();
          const travel = rect.height + viewportHeight * 0.38;
          const raw = Math.min(Math.max((viewportHeight - rect.top) / travel, 0), 1);
          const eased = easeOutCubic(raw);

          hero.style.setProperty('--scroll-progress', raw.toFixed(4));
          hero.style.setProperty('--hero-text-shift', `${eased * 14}px`);
          hero.style.setProperty('--hero-visual-shift', `${-8 + eased * 22}px`);
          hero.style.setProperty('--visual-tilt', `${-4 + eased * 9}deg`);
          hero.style.setProperty('--field-turn', `${eased * 8}deg`);
          hero.style.setProperty('--back-ring-drift', `${eased * 8}px`);
          hero.style.setProperty('--front-ring-drift', `${eased * 6}px`);
          hero.style.setProperty('--front-ring-turn', `${-2 + eased * 7}deg`);
          hero.style.setProperty('--front-ring-scale', `${1 + eased * 0.08}`);
          hero.style.setProperty('--rear-ring-scale', `${1 + eased * 0.05}`);
          hero.style.setProperty('--surface-turn', `${eased * 16}deg`);
          hero.style.setProperty('--aura-scale', `${1 + eased * 0.05}`);
          hero.style.setProperty('--aura-opacity', `${0.92 + eased * 0.08}`);
          hero.style.setProperty('--orb-saturate', `${1.02 + eased * 0.16}`);
          hero.style.setProperty('--orb-brightness', `${1 + eased * 0.04}`);
          hero.style.setProperty('--orb-outline-opacity', `${0.42 - eased * 0.2}`);
          hero.style.setProperty('--spark-drift', `${eased * -16}px`);
        });
      };

      const requestTick = () => {
        if (!rafId) rafId = window.requestAnimationFrame(update);
      };

      const handleMediaChange = () => {
        requestTick();
      };

      requestTick();
      window.addEventListener('scroll', requestTick, { passive: true });
      window.addEventListener('resize', requestTick);
      mediaQuery.addEventListener('change', handleMediaChange);

      window.__thenovaryOrbitCleanup = () => {
        if (rafId) window.cancelAnimationFrame(rafId);
        window.removeEventListener('scroll', requestTick);
        window.removeEventListener('resize', requestTick);
        mediaQuery.removeEventListener('change', handleMediaChange);
      };
    })();
  </script>
)}

<style>
  /* ---- Hero ---- */
  .hero {
    --scroll-progress: 0;
    --hero-text-shift: 0px;
    --hero-visual-shift: -8px;
    --visual-tilt: 0deg;
    --field-turn: 0deg;
    --back-ring-drift: 0px;
    --front-ring-drift: 0px;
    --front-ring-turn: 0deg;
    --front-ring-scale: 1;
    --rear-ring-scale: 1;
    --surface-turn: 0deg;
    --aura-scale: 1;
    --aura-opacity: 0.92;
    --orb-saturate: 1;
    --orb-brightness: 1;
    --orb-outline-opacity: 0.42;
    --spark-drift: 0px;
    padding-top: calc(var(--gnb-height) + var(--space-2xl));
    padding-bottom: var(--space-2xl);
    min-height: 88vh;
    display: flex;
    align-items: center;
    position: relative;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: var(--space-2xl);
    position: relative;
    z-index: 1;
    transform: translateY(-32px);
  }

  .hero--archive-preview {
    padding-top: calc(var(--gnb-height) + 30px);
    padding-bottom: 20px;
    min-height: calc(100vh - var(--gnb-height));
    align-items: center;
    overflow: hidden;
  }

  .hero--archive-preview .hero-inner {
    gap: clamp(28px, 4vw, 52px);
    transform: translateY(-10px);
    align-items: center;
  }

  .hero--archive-preview .hero-text {
    gap: var(--space-lg);
  }

  .hero--archive-preview .hero-visual {
    padding: var(--space-lg) var(--space-md);
    transform: none;
  }

  .hero--archive-preview .glass-comp {
    width: 360px;
    height: 360px;
  }

  .hero--archive-preview .card-main {
    width: 208px;
    height: 208px;
  }

  /* ---- Left: text ---- */
  .hero-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    transform: translateY(var(--hero-text-shift));
    opacity: calc(1 - (var(--scroll-progress) * 0.14));
    will-change: transform, opacity;
  }

  .hero-eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .hero-headline {
    font-size: clamp(36px, 4.5vw, 60px);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.05;
    color: var(--color-text-primary);
  }

  .hero-subtitle {
    font-size: 17px;
    color: var(--color-text-secondary);
    line-height: 1.75;
    max-width: 480px;
  }

  .hero-headline-note {
    font-size: 18px;
    font-weight: 600;
    line-height: 1.45;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    max-width: 520px;
    margin-top: calc(var(--space-sm) * -1);
  }

  .hero-cta-row {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  /* ---- Right: Glass composition ---- */
  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: var(--space-xl) 0;
    transform: translateY(var(--hero-visual-shift));
    will-change: transform;
  }

  .glass-comp {
    --orb-size: 264px;
    position: relative;
    width: 460px;
    height: 460px;
    flex-shrink: 0;
    isolation: isolate;
    transform: rotate(var(--visual-tilt));
    transform-origin: center;
    will-change: transform;
  }

  .glass-comp::before,
  .glass-comp::after,
  .card-main-wrap::before,
  .card-main-wrap::after {
    content: '';
    position: absolute;
    pointer-events: none;
  }

  .glass-comp::before {
    inset: 13% -3%;
    border-radius: 50%;
    border: 1.5px solid rgba(176, 191, 255, 0.34);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.46) inset,
      0 0 92px rgba(154, 171, 255, 0.16),
      0 0 52px rgba(188, 244, 255, 0.12);
    transform: translateY(var(--back-ring-drift)) rotate(calc(-18deg + var(--field-turn)));
    opacity: 0.68;
    z-index: 0;
    animation: orbit-field 18s linear infinite;
  }

  .glass-comp::after {
    left: -6%;
    right: -6%;
    top: 37.5%;
    height: 28%;
    border-radius: 50%;
    background:
      linear-gradient(
        90deg,
        rgba(255, 255, 255, 0) 0%,
        rgba(255, 255, 255, 0.52) 14%,
        rgba(255, 255, 255, 0) 22%,
        rgba(255, 255, 255, 0) 100%
      ),
      linear-gradient(
        90deg,
        rgba(255, 255, 255, 0) 0%,
        rgba(255, 228, 239, 0.58) 10%,
        rgba(173, 237, 255, 0.74) 28%,
        rgba(147, 157, 255, 0.84) 47%,
        rgba(255, 240, 246, 0.66) 64%,
        rgba(168, 236, 255, 0.68) 82%,
        rgba(255, 255, 255, 0) 100%
      );
    -webkit-mask: radial-gradient(closest-side, transparent calc(100% - 20px), #000 calc(100% - 15px), #000 99%, transparent 100%);
    mask: radial-gradient(closest-side, transparent calc(100% - 20px), #000 calc(100% - 15px), #000 99%, transparent 100%);
    filter: blur(0.8px);
    transform: translateY(var(--back-ring-drift)) rotate(calc(-15deg + var(--field-turn))) scaleX(var(--rear-ring-scale));
    opacity: 0.68;
    z-index: 1;
    box-shadow:
      0 0 70px rgba(160, 180, 255, 0.16),
      0 0 42px rgba(188, 244, 255, 0.18);
  }

  .comp-glow {
    display: none;
  }

  .card-main-wrap {
    position: absolute;
    top: 50%;
    left: 50%;
    width: var(--orb-size);
    height: var(--orb-size);
    transform: translate(-50%, -50%);
    animation: main-float 10s ease-in-out infinite;
    z-index: 2;
  }

  .card-main-wrap::before {
    left: 50%;
    top: 53%;
    width: 446px;
    height: 148px;
    transform: translate(-50%, calc(-50% + var(--front-ring-drift))) rotate(calc(17deg + var(--front-ring-turn))) scaleX(var(--front-ring-scale));
    border-radius: 50%;
    background:
      linear-gradient(
        90deg,
        rgba(255, 255, 255, 0) 0%,
        rgba(255, 255, 255, 0.88) 14%,
        rgba(255, 255, 255, 0.22) 22%,
        rgba(255, 255, 255, 0) 30%,
        rgba(255, 255, 255, 0) 100%
      ),
      linear-gradient(
        90deg,
        rgba(255, 255, 255, 0) 0%,
        rgba(255, 229, 240, 0.72) 12%,
        rgba(188, 244, 255, 0.92) 31%,
        rgba(152, 164, 255, 1) 49%,
        rgba(255, 243, 247, 0.84) 68%,
        rgba(176, 240, 255, 0.86) 84%,
        rgba(255, 255, 255, 0) 100%
      );
    -webkit-mask: radial-gradient(closest-side, transparent calc(100% - 26px), #000 calc(100% - 18px), #000 99%, transparent 100%);
    mask: radial-gradient(closest-side, transparent calc(100% - 26px), #000 calc(100% - 18px), #000 99%, transparent 100%);
    clip-path: inset(46% 0 0 0);
    box-shadow:
      0 0 58px rgba(154, 171, 255, 0.24),
      0 0 30px rgba(194, 245, 255, 0.2),
      0 0 18px rgba(255, 235, 244, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.36);
    opacity: 0.98;
    z-index: 4;
    animation: orbit-sway 14s ease-in-out infinite;
    filter: saturate(1.12) brightness(1.05);
  }

  .card-main-wrap::after {
    left: 50%;
    top: 50%;
    width: 334px;
    height: 334px;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background:
      radial-gradient(circle, rgba(162, 179, 255, 0.24) 0%, rgba(162, 179, 255, 0.09) 34%, transparent 70%);
    filter: blur(24px);
    opacity: var(--aura-opacity);
    z-index: -2;
    transform: translate(-50%, -50%) scale(var(--aura-scale));
  }

  .card-main {
    width: 100%;
    height: 100%;
    background:
      radial-gradient(circle at 31% 22%, rgba(255, 255, 255, 0.96) 0%, rgba(255, 255, 255, 0.42) 11%, transparent 28%),
      radial-gradient(circle at 73% 72%, rgba(137, 230, 255, 0.44) 0%, rgba(137, 230, 255, 0.08) 19%, transparent 38%),
      radial-gradient(circle at 58% 56%, rgba(164, 145, 255, 0.34) 0%, rgba(164, 145, 255, 0.1) 24%, transparent 48%),
      linear-gradient(
        160deg,
        rgba(112, 145, 255, 0.96) 0%,
        rgba(162, 148, 255, 0.94) 23%,
        rgba(255, 230, 240, 0.9) 42%,
        rgba(173, 240, 255, 0.88) 60%,
        rgba(118, 154, 255, 0.94) 78%,
        rgba(238, 230, 255, 0.88) 100%
      );
    backdrop-filter: blur(28px) saturate(1.15);
    -webkit-backdrop-filter: blur(28px) saturate(1.15);
    border: 1px solid rgba(255, 255, 255, var(--orb-outline-opacity));
    border-radius: 50%;
    overflow: hidden;
    box-shadow:
      0 48px 92px rgba(132, 145, 205, 0.18),
      0 16px 34px rgba(0, 0, 0, 0.06),
      0 0 0 14px rgba(255, 255, 255, 0.025),
      inset 0 1px 0 rgba(255, 255, 255, 0.94),
      inset 0 -40px 72px rgba(255, 255, 255, 0.14),
      inset -24px -30px 56px rgba(74, 103, 198, 0.16),
      inset 20px 18px 34px rgba(255, 255, 255, 0.08);
    position: relative;
    transform: rotate(var(--surface-turn));
    filter: saturate(var(--orb-saturate)) brightness(var(--orb-brightness));
    will-change: transform, filter, border-color;
  }

  .card-main::before {
    content: '';
    position: absolute;
    inset: -8%;
    border-radius: 50%;
    background:
      repeating-linear-gradient(
        168deg,
        rgba(255, 255, 255, 0) 0 12px,
        rgba(255, 255, 255, 0.18) 12px 16px,
        rgba(137, 152, 255, 0.44) 16px 32px,
        rgba(183, 158, 255, 0.42) 32px 46px,
        rgba(255, 226, 239, 0.44) 46px 60px,
        rgba(138, 226, 255, 0.34) 60px 76px,
        rgba(255, 255, 255, 0) 76px 92px
      ),
      radial-gradient(circle at 66% 60%, rgba(102, 225, 255, 0.22) 0%, transparent 18%),
      radial-gradient(circle at 32% 28%, rgba(190, 162, 255, 0.24) 0%, transparent 22%),
      radial-gradient(circle at 76% 44%, rgba(255, 245, 250, 0.18) 0%, transparent 14%);
    mix-blend-mode: screen;
    opacity: 0.92;
    transform: rotate(-15deg) scale(1.08);
    filter: blur(5px);
  }

  .card-main::after {
    content: '';
    position: absolute;
    inset: 8% 14% 50% 18%;
    border-radius: 50%;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(255, 255, 255, 0.08));
    filter: blur(14px);
    transform: rotate(-24deg);
    opacity: 0.88;
  }

  .card-gradient {
    position: absolute;
    inset: 8%;
    border-radius: 50%;
    background:
      radial-gradient(circle at 28% 26%, rgba(255, 232, 241, 0.86) 0%, transparent 20%),
      radial-gradient(circle at 72% 72%, rgba(170, 240, 255, 0.72) 0%, transparent 22%),
      radial-gradient(circle at 48% 44%, rgba(161, 140, 255, 0.3) 0%, transparent 30%),
      conic-gradient(
        from 96deg at 50% 50%,
        rgba(255, 255, 255, 0) 0deg,
        rgba(157, 175, 255, 0.42) 74deg,
        rgba(255, 255, 255, 0) 150deg,
        rgba(255, 224, 238, 0.36) 228deg,
        rgba(255, 255, 255, 0) 360deg
      );
    filter: blur(18px);
    mix-blend-mode: screen;
    opacity: 0.94;
    pointer-events: none;
  }

  .card-gradient::before,
  .card-gradient::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    pointer-events: none;
  }

  .card-gradient::before {
    inset: -8%;
    background:
      radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0) 56%, rgba(255, 238, 245, 0.08) 63%, rgba(174, 235, 255, 0.26) 72%, rgba(178, 166, 255, 0.22) 78%, transparent 87%);
    mix-blend-mode: screen;
    filter: blur(5px);
    opacity: 0.96;
  }

  .card-gradient::after {
    inset: 4%;
    background:
      radial-gradient(circle at 68% 58%, rgba(86, 98, 182, 0.22) 0%, rgba(86, 98, 182, 0.14) 22%, transparent 46%),
      radial-gradient(circle at 34% 72%, rgba(86, 98, 182, 0.14) 0%, transparent 34%);
    mix-blend-mode: multiply;
    filter: blur(18px);
    opacity: 0.48;
  }

  .appcard {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 18px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, rgba(255, 255, 255, 0.8) 100%);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.95);
    border-radius: 24px;
    box-shadow:
      0 22px 42px rgba(122, 132, 171, 0.16),
      0 4px 14px rgba(91, 92, 255, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 1);
    white-space: nowrap;
    z-index: 4;
  }

  .appcard-icon {
    width: 44px;
    height: 44px;
    border-radius: 14px;
    object-fit: cover;
    flex-shrink: 0;
    box-shadow: 0 10px 24px rgba(122, 132, 171, 0.18);
  }

  .appcard-name {
    font-size: 16px;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
  }

  .appcard-1 {
    top: 4%;
    right: 2%;
    animation: float-a 6s ease-in-out infinite;
  }

  .appcard-2 {
    top: 44%;
    left: -6%;
    animation: float-b 7.5s ease-in-out infinite 2s;
  }

  .appcard-3 {
    bottom: 7%;
    right: 0;
    animation: float-c 5.5s ease-in-out infinite 4s;
  }

  .cdot {
    position: absolute;
    z-index: 5;
    border-radius: 50%;
    pointer-events: none;
    background: radial-gradient(
      circle,
      rgba(255, 255, 255, 0.98) 0%,
      rgba(255, 255, 255, 0.92) 10%,
      rgba(255, 255, 255, 0.2) 28%,
      transparent 68%
    );
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.4),
      0 0 24px var(--spark-halo);
    opacity: 0.92;
  }

  .cdot::before,
  .cdot::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    border-radius: 999px;
    transform-origin: center;
    filter: drop-shadow(0 0 6px var(--spark-halo));
  }

  .cdot::before {
    width: 2px;
    height: 100%;
    transform: translate(-50%, -50%) rotate(var(--spark-rotate));
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(255, 255, 255, 0.08) 12%,
      var(--spark-tint) 32%,
      #ffffff 50%,
      var(--spark-tint) 68%,
      rgba(255, 255, 255, 0.08) 88%,
      transparent 100%
    );
  }

  .cdot::after {
    width: 100%;
    height: 2px;
    transform: translate(-50%, -50%) rotate(var(--spark-rotate));
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.08) 12%,
      var(--spark-tint) 32%,
      #ffffff 50%,
      var(--spark-tint) 68%,
      rgba(255, 255, 255, 0.08) 88%,
      transparent 100%
    );
  }

  .cdot-1 {
    --spark-tint: rgba(192, 132, 252, 0.92);
    --spark-halo: rgba(192, 132, 252, 0.45);
    --spark-rotate: -14deg;
