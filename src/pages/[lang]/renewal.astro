---
import RenewalLayout from '../../components/RenewalLayout.astro';
import RenewalAppCard from '../../components/RenewalAppCard.astro';
import { getLang, t } from '../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'ko' } },
    { params: { lang: 'en' } },
  ];
}

const lang = getLang(Astro.params.lang);

const appFiles = import.meta.glob('../../data/apps/*.json', { eager: true });
const apps = Object.values(appFiles)
  .map((mod) => ((mod as { default?: unknown }).default ?? mod))
  .sort((a: any, b: any) => b.order - a.order);
---

<RenewalLayout
  lang={lang}
  title="thenovary"
  description={lang === 'ko'
    ? '혁신적인 앱을 만드는 스튜디오 thenovary'
    : 'thenovary — A studio that crafts innovative apps'}
>
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <p class="hero-eyebrow">{t(lang, 'home.eyebrow')}</p>
        <h1 class="hero-headline">
          <span>{t(lang, 'home.headline1')}</span><br />
          <span>{t(lang, 'home.headline2')}</span>
        </h1>
        {lang === 'ko' && <p class="hero-headline-note">{t(lang, 'home.headlineNote')}</p>}
        <p class="hero-subtitle">{t(lang, 'home.subtitle')}</p>
        <div class="hero-cta-row">
          <a href="#apps" class="btn btn-primary">{t(lang, 'home.ctaPrimary')}</a>
          <a href={`/${lang}/renewal/contact/`} class="btn btn-secondary">{t(lang, 'home.ctaSecondary')}</a>
        </div>
      </div>

      <div class="hero-visual">
        <div class="glass-comp">
          <div class="comp-glow glow-violet"></div>
          <div class="comp-glow glow-blue"></div>
          <div class="comp-glow glow-cyan"></div>

          <div class="card-main-wrap">
            <div class="card-main">
              <div class="card-gradient"></div>

              <div class="card-footer">
                <span class="card-brand-text">thenovary</span>
                <span class="card-badge">App Studio</span>
              </div>
            </div>
          </div>

          <div class="appcard appcard-1">
            <img src="/icons/pommo.png" alt="Pommo" class="appcard-icon" />
            <span class="appcard-name">Pommo</span>
          </div>

          <div class="appcard appcard-2">
            <img src="/icons/deepread.png" alt="deepread" class="appcard-icon" />
            <span class="appcard-name">deepread</span>
          </div>

          <div class="appcard appcard-3">
            <img src="/icons/Grately.png" alt="Grately" class="appcard-icon" />
            <span class="appcard-name">Grately</span>
          </div>

          <div class="cdot cdot-1"></div>
          <div class="cdot cdot-2"></div>
          <div class="cdot cdot-3"></div>
          <div class="cdot cdot-4"></div>
          <div class="cdot cdot-5"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-sm apps-section" id="apps">
    <div class="container">
      <h2 class="section-title">{t(lang, 'home.appsTitle')}</h2>
      <div class="apps-grid">
        {apps.map((app: any) => (
          <RenewalAppCard app={app} lang={lang} />
        ))}
      </div>
    </div>
  </section>
</RenewalLayout>

<style>
  .hero {
    padding-top: calc(var(--gnb-height) + var(--space-2xl));
    padding-bottom: var(--space-2xl);
    min-height: 88vh;
    display: flex;
    align-items: center;
    position: relative;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: var(--space-2xl);
    position: relative;
    z-index: 1;
    transform: translateY(-32px);
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .hero-eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .hero-headline {
    font-size: clamp(36px, 4.5vw, 60px);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.05;
    color: var(--color-text-primary);
  }

  .hero-subtitle {
    font-size: 17px;
    color: var(--color-text-secondary);
    line-height: 1.75;
    max-width: 480px;
  }

  .hero-headline-note {
    font-size: 18px;
    font-weight: 600;
    line-height: 1.45;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    max-width: 520px;
    margin-top: calc(var(--space-sm) * -1);
  }

  .hero-cta-row {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: var(--space-xl) var(--space-lg);
    transform: translateY(-22px);
  }

  .glass-comp {
    position: relative;
    width: 340px;
    height: 420px;
    flex-shrink: 0;
  }

  .glass-comp::before {
    content: '';
    position: absolute;
    inset: 6% -18% auto;
    height: 104px;
    border-radius: 999px;
    background:
      linear-gradient(
        116deg,
        transparent 10%,
        rgba(255, 255, 255, 0.96) 22%,
        rgba(255, 222, 239, 0.58) 31%,
        rgba(255, 240, 188, 0.52) 38%,
        rgba(186, 244, 255, 0.56) 48%,
        rgba(162, 178, 255, 0.46) 58%,
        transparent 80%
      );
    filter: blur(10px);
    opacity: 0.7;
    transform: rotate(-24deg);
  }

  .glass-comp::after {
    content: '';
    position: absolute;
    inset: 24% 12% 12%;
    border-radius: 34px;
    background: radial-gradient(circle at 20% 18%, rgba(255, 236, 245, 0.42) 0%, transparent 34%),
      radial-gradient(circle at 82% 76%, rgba(193, 244, 255, 0.38) 0%, transparent 34%);
    filter: blur(24px);
    opacity: 0.82;
  }

  .comp-glow {
    display: none;
  }

  .card-main-wrap {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(-4deg);
    animation: main-float 9s ease-in-out infinite;
  }

  .card-main {
    width: 200px;
    height: 260px;
    background: rgba(255, 255, 255, 0.56);
    backdrop-filter: blur(28px) saturate(160%);
    -webkit-backdrop-filter: blur(28px) saturate(160%);
    border: 1px solid rgba(255, 255, 255, 0.92);
    border-radius: 28px;
    overflow: hidden;
    box-shadow:
      0 34px 80px rgba(124, 136, 188, 0.18),
      0 8px 24px rgba(0, 0, 0, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.94);
    position: relative;
  }

  .card-gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 22% 22%, rgba(255, 218, 238, 0.62) 0%, transparent 54%),
      radial-gradient(ellipse at 82% 76%, rgba(177, 241, 255, 0.5) 0%, transparent 52%),
      radial-gradient(ellipse at 62% 30%, rgba(255, 244, 196, 0.44) 0%, transparent 46%),
      radial-gradient(ellipse at 48% 56%, rgba(170, 184, 255, 0.38) 0%, transparent 58%),
      linear-gradient(145deg, rgba(255, 255, 255, 0.74) 0%, rgba(241, 247, 255, 0.54) 100%);
  }

  .card-footer {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 16px 18px;
    background: linear-gradient(to top, rgba(255, 255, 255, 0.92) 0%, transparent 100%);
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .card-brand-text {
    font-size: 14px;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
  }

  .card-badge {
    display: inline-flex;
    align-self: flex-start;
    padding: 3px 9px;
    border-radius: var(--radius-pill);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.02em;
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid rgba(255, 255, 255, 0.92);
    color: var(--color-accent);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.96);
  }

  .appcard {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: rgba(255, 255, 255, 0.78);
    backdrop-filter: blur(22px) saturate(160%);
    -webkit-backdrop-filter: blur(22px) saturate(160%);
    border: 1px solid rgba(255, 255, 255, 0.95);
    border-radius: 16px;
    box-shadow:
      0 14px 34px rgba(122, 132, 171, 0.14),
      inset 0 1px 0 rgba(255, 255, 255, 1);
    white-space: nowrap;
    z-index: 2;
  }

  .appcard-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    object-fit: cover;
    flex-shrink: 0;
    box-shadow: 0 6px 16px rgba(34, 41, 62, 0.12);
  }

  .appcard-name {
    font-size: 13px;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
  }

  .appcard-1 {
    top: 2%;
    right: -16px;
    animation: float-a 6s ease-in-out infinite;
  }

  .appcard-2 {
    top: 42%;
    left: -20px;
    animation: float-b 7.5s ease-in-out infinite 2s;
  }

  .appcard-3 {
    bottom: 4%;
    right: -8px;
    animation: float-c 5.5s ease-in-out infinite 4s;
  }

  .cdot {
    position: absolute;
    z-index: 3;
    border-radius: 50%;
    pointer-events: none;
    background: radial-gradient(
      circle,
      rgba(255, 255, 255, 0.98) 0%,
      rgba(255, 255, 255, 0.92) 10%,
      rgba(255, 255, 255, 0.2) 28%,
      transparent 68%
    );
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.4),
      0 0 24px var(--spark-halo);
    opacity: 0.92;
  }

  .cdot::before,
  .cdot::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    border-radius: 999px;
    transform-origin: center;
    filter: drop-shadow(0 0 6px var(--spark-halo));
  }

  .cdot::before {
    width: 2px;
    height: 100%;
    transform: translate(-50%, -50%) rotate(var(--spark-rotate));
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(255, 255, 255, 0.08) 12%,
      var(--spark-tint) 32%,
      #ffffff 50%,
      var(--spark-tint) 68%,
      rgba(255, 255, 255, 0.08) 88%,
      transparent 100%
    );
  }

  .cdot::after {
    width: 100%;
    height: 2px;
    transform: translate(-50%, -50%) rotate(var(--spark-rotate));
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.08) 12%,
      var(--spark-tint) 32%,
      #ffffff 50%,
      var(--spark-tint) 68%,
      rgba(255, 255, 255, 0.08) 88%,
      transparent 100%
    );
  }

  .cdot-1 {
    --spark-tint: rgba(255, 187, 222, 0.92);
    --spark-halo: rgba(255, 187, 222, 0.46);
    --spark-rotate: -14deg;
    width: 24px;
    height: 24px;
    top: 18%;
    left: 4%;
    animation: sparkle-a 5.8s ease-in-out infinite 0.8s;
  }

  .cdot-2 {
    --spark-tint: rgba(110, 220, 255, 0.9);
    --spark-halo: rgba(110, 220, 255, 0.42);
    --spark-rotate: 12deg;
    width: 18px;
    height: 18px;
    bottom: 22%;
    right: 5%;
    animation: sparkle-b 7.2s ease-in-out infinite 2.6s;
  }

  .cdot-3 {
    --spark-tint: rgba(154, 171, 255, 0.92);
    --spark-halo: rgba(154, 171, 255, 0.42);
    --spark-rotate: 22deg;
    width: 20px;
    height: 20px;
    top: 57%;
    left: 1.5%;
    animation: sparkle-c 6.8s ease-in-out infinite 4.2s;
  }

  .cdot-4 {
    --spark-tint: rgba(255, 223, 166, 0.9);
    --spark-halo: rgba(255, 223, 166, 0.38);
    --spark-rotate: -8deg;
    width: 18px;
    height: 18px;
    top: 14%;
    right: 10%;
    animation: sparkle-b 6.4s ease-in-out infinite 1.8s;
    display: none;
  }

  .cdot-5 {
    --spark-tint: rgba(129, 206, 255, 0.92);
    --spark-halo: rgba(129, 206, 255, 0.36);
    --spark-rotate: 16deg;
    width: 22px;
    height: 22px;
    top: 66%;
    right: 2.5%;
    animation: sparkle-a 7.1s ease-in-out infinite 3.4s;
    display: none;
  }

  @keyframes main-float {
    0%,
    100% {
      transform: translate(-50%, -50%) rotate(-4deg) translateY(0);
    }

    50% {
      transform: translate(-50%, -50%) rotate(-4deg) translateY(-10px);
    }
  }

  @keyframes float-a {
    0%,
    100% {
      transform: translateY(0);
    }

    50% {
      transform: translateY(-10px);
    }
  }

  @keyframes float-b {
    0%,
    100% {
      transform: translateY(0);
    }

    50% {
      transform: translateY(-8px);
    }
  }

  @keyframes float-c {
    0%,
    100% {
      transform: translateY(0);
    }

    50% {
      transform: translateY(-12px);
    }
  }

  @keyframes sparkle-a {
    0%,
    100% {
      transform: translateY(0) scale(0.92) rotate(0deg);
      opacity: 0.78;
    }

    50% {
      transform: translateY(-10px) scale(1.06) rotate(8deg);
      opacity: 1;
    }
  }

  @keyframes sparkle-b {
    0%,
    100% {
      transform: translateY(0) scale(0.94) rotate(0deg);
      opacity: 0.72;
    }

    50% {
      transform: translateY(-8px) scale(1.08) rotate(-6deg);
      opacity: 0.98;
    }
  }

  @keyframes sparkle-c {
    0%,
    100% {
      transform: translateY(0) scale(0.9) rotate(0deg);
      opacity: 0.75;
    }

    50% {
      transform: translateY(-12px) scale(1.04) rotate(10deg);
      opacity: 1;
    }
  }

  .apps-section {
    padding-bottom: var(--space-3xl);
    scroll-margin-top: var(--gnb-height);
  }

  .section-title {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    margin-bottom: var(--space-lg);
  }

  .apps-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  @media (min-width: 640px) {
    .apps-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding-top: calc(var(--gnb-height) + 8px);
      padding-bottom: var(--space-xl);
    }

    .hero-inner {
      grid-template-columns: 1fr;
      gap: 12px;
      transform: none;
    }

    .hero-eyebrow {
      font-size: 11px;
    }

    .hero-headline {
      font-size: 36px;
      letter-spacing: -0.03em;
    }

    .hero-subtitle {
      font-size: 15px;
      line-height: 1.65;
    }

    .hero-cta-row {
      gap: var(--space-sm);
    }

    .hero-text {
      gap: var(--space-md);
      order: 2;
    }

    .hero-visual {
      position: relative;
      order: 1;
      padding: 10px 0 18px;
      transform: none;
      overflow: visible;
    }

    .glass-comp {
      width: 236px;
      height: 308px;
      margin: 0 auto;
    }

    .glass-comp::before {
      inset: 8% -12% auto;
      height: 84px;
    }

    .card-main {
      width: 148px;
      height: 196px;
      border-radius: 22px;
      box-shadow:
        0 20px 54px rgba(122, 132, 171, 0.16),
        0 6px 18px rgba(0, 0, 0, 0.05),
        inset 0 1px 0 rgba(255, 255, 255, 0.9);
    }

    .appcard-1 {
      top: 4%;
      right: -8px;
    }

    .appcard-2 {
      top: 44%;
      left: -8px;
    }

    .appcard-3 {
      bottom: 4%;
      right: -8px;
    }

    .appcard {
      padding: 7px 10px;
      gap: 7px;
      border-radius: 12px;
    }

    .appcard-icon {
      width: 26px;
      height: 26px;
      border-radius: 7px;
    }

    .appcard-name {
      font-size: 11px;
    }

    .cdot {
      display: block;
      opacity: 1;
      box-shadow:
        inset 0 0 0 1px rgba(255, 255, 255, 0.5),
        0 0 30px var(--spark-halo);
    }

    .cdot-1 {
      width: 22px;
      height: 22px;
      top: 17%;
      left: -8%;
    }

    .cdot-2 {
      width: 18px;
      height: 18px;
      bottom: 18%;
      right: -7%;
    }

    .cdot-3 {
      display: block;
      width: 18px;
      height: 18px;
      top: 57%;
      left: -8%;
    }

    .cdot-4,
    .cdot-5,
    .comp-glow {
      display: none;
    }
  }
</style>
