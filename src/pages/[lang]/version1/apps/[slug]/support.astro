---
/**
 * App Support page
 * Route: /[lang]/apps/[slug]/support/
 */
import Version1Layout from '../../../../../components/Version1Layout.astro';
import Version1AppSubNav from '../../../../../components/Version1AppSubNav.astro';
import { getLang, t, getLocalizedName } from '../../../../../i18n/utils';

export async function getStaticPaths() {
  const langs = ['ko', 'en'];
  const appFiles = import.meta.glob('../../../../../data/apps/*.json', { eager: true });
  const apps = Object.values(appFiles).map((m: any) => m.default ?? m);
  return langs.flatMap(lang =>
    apps.map((app: any) => ({ params: { lang, slug: app.slug }, props: { app } }))
  );
}

const { app } = Astro.props;
const lang = getLang(Astro.params.lang);
const localizedName = getLocalizedName(app.name, lang);

const email = app.support?.email ?? 'infodeskline@gmail.com';
const defaultSections = [
  {
    title: {
      ko: '자주 묻는 질문',
      en: 'Frequently Asked Questions',
    },
    content: {
      ko: `${localizedName} 사용 중 문제가 발생하거나 궁금한 점이 있으시면 아래 이메일로 문의해 주세요. 최대한 빠르게 답변 드리겠습니다.`,
      en: `If you experience any issues or have questions while using ${localizedName}, please contact us via email below. We'll get back to you as soon as possible.`,
    },
  },
  {
    title: {
      ko: '데이터 관련 문제',
      en: 'Data-related Issues',
    },
    content: {
      ko: '앱을 재설치하면 기기에 저장된 데이터가 삭제될 수 있습니다. 데이터 복구는 지원되지 않으므로 중요한 기록은 미리 백업해 두시기 바랍니다.',
      en: 'Reinstalling the app may delete data stored on your device. Data recovery is not supported, so please back up important records in advance.',
    },
  },
  {
    title: {
      ko: '버그 신고',
      en: 'Bug Reports',
    },
    content: {
      ko: '버그 발견 시 기기 모델, OS 버전, 앱 버전과 함께 문의 이메일로 신고해 주시면 빠른 수정에 도움이 됩니다.',
      en: 'If you find a bug, please report it to our support email along with your device model, OS version, and app version. This helps us fix issues faster.',
    },
  },
];
const sections = app.support?.sections?.length ? app.support.sections : defaultSections;
---

<Version1Layout
  lang={lang}
  title={`${t(lang, 'appNav.support')} — ${localizedName}`}
  description={`${localizedName} ${t(lang, 'appNav.support')}`}
>
  <section class="section support-page">
    <div class="container">

      <a href={`/${lang}/version1/`} class="back-link">← {t(lang, 'app.backToHome')}</a>

      <div class="page-header">
        <img src={app.icon} alt={localizedName} class="app-icon" width="48" height="48" />
        <div>
          <p class="app-name-label">{localizedName}</p>
          <h1 class="page-title">{t(lang, 'appNav.support')}</h1>
        </div>
      </div>

      <Version1AppSubNav lang={lang} slug={app.slug} active="support" />

      <!-- Email contact card -->
      <div class="contact-card glass-card">
        <div class="contact-info">
          <p class="contact-label">{t(lang, 'appPage.supportEmail')}</p>
          <a href={`mailto:${email}`} class="contact-email">{email}</a>
        </div>
        <a href={`mailto:${email}`} class="btn btn-primary">
          {t(lang, 'appPage.sendEmail')}
        </a>
      </div>

      <!-- Support sections (FAQ, etc.) -->
      {sections.length > 0 && (
        <div class="support-sections">
          {sections.map((section: any) => (
            <div class="support-section glass-card">
              <h2 class="section-title">
                {section.title?.[lang] ?? section.title?.['en'] ?? ''}
              </h2>
              <p class="section-content">
                {section.content?.[lang] ?? section.content?.['en'] ?? ''}
              </p>
            </div>
          ))}
        </div>
      )}

    </div>
  </section>
</Version1Layout>

<style>
  .support-page {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-3xl);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    font-size: 15px;
    font-weight: 500;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
    min-height: 44px;
    transition: color var(--duration-fast) var(--ease-smooth);
  }
  .back-link:hover { color: var(--color-accent-hover); }

  .page-header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .app-icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-sm);
    flex-shrink: 0;
  }

  .app-name-label {
    font-size: 13px;
    color: #1d1d1f;
    margin-bottom: 2px;
  }

  .page-title {
    font-size: clamp(22px, 4vw, 32px);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
  }

  .contact-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    padding: var(--space-lg) var(--space-xl);
    margin-bottom: var(--space-lg);
    flex-wrap: wrap;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .contact-label {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-tertiary);
  }

  .contact-email {
    font-size: 16px;
    font-weight: 500;
    color: var(--color-accent);
    min-height: 44px;
    display: flex;
    align-items: center;
    transition: color var(--duration-fast) var(--ease-smooth);
  }
  .contact-email:hover { color: var(--color-accent-hover); }

  .support-sections {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .support-section {
    padding: var(--space-lg) var(--space-xl);
  }

  .section-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: var(--space-sm);
  }

  .section-content {
    font-size: 15px;
    line-height: 1.8;
    color: var(--color-text-secondary);
  }

  @media (max-width: 480px) {
    .contact-card { flex-direction: column; align-items: flex-start; }
    .contact-card .btn { width: 100%; justify-content: center; }
  }
</style>
